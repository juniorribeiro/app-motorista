# ============================================================
# Variáveis de ambiente — Produção (DriverDash)
# ============================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.prod.example .env.prod
#   2. Preencha TODOS os valores abaixo com senhas FORTES
#   3. NUNCA comite o arquivo .env.prod no Git
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=ALTERE_PARA_SENHA_FORTE_ROOT
MYSQL_DATABASE=driver_dash
MYSQL_USER=app_user
MYSQL_PASSWORD=ALTERE_PARA_SENHA_FORTE_APP

# --- JWT ---
# Gere com: openssl rand -base64 64
JWT_SECRET=ALTERE_PARA_CHAVE_JWT_SEGURA
JWT_EXPIRES_IN=7d
